# AlphaLens 환경 설정
# 복사하여 .env 파일로 사용하세요

# 서버 설정
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 인증 (비어있으면 인증 비활성화 - 개발 모드)
API_KEY=your-secret-key-here

# JWT 설정 (비어있으면 JWT 비활성 - API Key만 사용)
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS 및 Rate Limit
CORS_ORIGINS=http://localhost:8000
RATE_LIMIT_PER_MINUTE=60

# 캐시 TTL (초)
CACHE_TTL_STOCK=300
CACHE_TTL_NEWS=600
CACHE_TTL_SCORING=300

# PostgreSQL (비어있으면 DB 비활성화 - 인메모리 캐시만 사용)
DATABASE_URL=postgresql+asyncpg://alphalens:alphalens_secret@localhost:5432/alphalens
POSTGRES_PASSWORD=alphalens_secret
